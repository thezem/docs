{
  "$schema": "https://mintlify.com/docs.json",
  "name": "ouim/docs",
  "theme": "maple",
  "favicon": "/logo.svg",
  "colors": {
    "primary": "#DA7756",
    "light": "#e08970",
    "dark": "#BD5D3A"
  },
  "contextual": {
    "options": ["copy", "claude", "grok", "mcp"]
  },

  "background": {
    "color": {
      "light": "#FAF9F5",

      "dark": "#1a1814"
    }
  },
  "fonts": {
    "heading": {
      "family": "Google Sans"
    },
    "body": {
      "family": "Google Sans"
    }
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/ouim-me"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/ouim-me"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Reacher",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["reacher/introduction", "reacher/quickstart", "reacher/connecting-to-claude"]
          },
          {
            "group": "Configuration",
            "pages": [
              "reacher/configuration/environment-variables",
              "reacher/configuration/reacher-config",
              "reacher/configuration/domain-allowlist"
            ]
          },
          {
            "group": "Tools",
            "pages": [
              "reacher/tools/overview",
              "reacher/tools/ssh-exec",
              "reacher/tools/tailscale-status",
              "reacher/tools/fetch-external",
              "reacher/tools/github-search",
              "reacher/tools/gist-kb",
              "reacher/tools/browser"
            ]
          },
          {
            "group": "Deployment",
            "pages": [
              "reacher/deployment/docker",
              "reacher/deployment/bare-node",
              "reacher/deployment/easypanel",
              "reacher/deployment/railway-render"
            ]
          },
          {
            "group": "Operations",
            "pages": [
              "reacher/operations/safety",
              "reacher/operations/audit-log",
              "reacher/operations/dry-run",
              "reacher/operations/troubleshooting"
            ]
          },
          {
            "group": "Extending",
            "pages": ["reacher/extending/adding-tools", "reacher/extending/token-injection"]
          }
        ]
      },
      {
        "tab": "simple-logto",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["simple-logto/introduction", "simple-logto/installation", "simple-logto/quickstart"]
          },
          {
            "group": "Frontend",
            "pages": [
              "simple-logto/frontend/auth-provider",
              "simple-logto/frontend/user-center",
              "simple-logto/frontend/callback-page",
              "simple-logto/frontend/use-auth",
              "simple-logto/frontend/route-protection"
            ]
          },
          {
            "group": "Backend",
            "pages": [
              "simple-logto/backend/overview",
              "simple-logto/backend/express-middleware",
              "simple-logto/backend/nextjs-integration",
              "simple-logto/backend/generic-usage"
            ]
          },
          {
            "group": "Configuration",
            "pages": [
              "simple-logto/configuration/bundler-setup",
              "simple-logto/configuration/guest-mode",
              "simple-logto/configuration/custom-navigation"
            ]
          },
          {
            "group": "Examples",
            "pages": ["simple-logto/examples/react-spa", "simple-logto/examples/nextjs-app", "simple-logto/examples/protected-routes"]
          }
        ]
      }
    ]
  }
}
